MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimaxi.com

# Optional overrides for the local OCR bridge.
OCR_BRIDGE_HOST=127.0.0.1
OCR_BRIDGE_PORT=8765
OCR_BRIDGE_BODY_LIMIT_MB=25

